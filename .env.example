# Copy this to .env and fill in your values
# Never commit .env to git

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── LangSmith (optional — set LANGCHAIN_TRACING_V2=false to disable) ─────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-key-here
LANGCHAIN_PROJECT=wealth-manager-dev
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# ── Database (overridden by docker-compose for container) ─────────────────────
DATABASE_URL=postgresql+asyncpg://wm_user:wm_password@localhost:5432/wealth_manager

# ── ChromaDB (overridden by docker-compose for container) ─────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
