# Normalize line endings: LF in the repo, OS-native on checkout
* text=auto

# Force LF for these file types regardless of OS
*.py   text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sh   text eol=lf

# Binary files — no line-ending conversion
*.docx binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.pdf  binary
